# ============================================================
# DailyDex — Environment configuration template
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── Web Authentication (required for public/VPS deployments) ────────────────
DAILYDEX_AUTH_ENABLED=1
# Generate with: openssl rand -hex 32
FLASK_SECRET_KEY=
# One-time code required to create the first and only workspace account.
# Generate with: openssl rand -base64 24
AUTH_INVITE_CODE=
AUTH_ALLOW_SIGNUP=1
AUTH_SESSION_HOURS=12
SESSION_COOKIE_SECURE=1
AUTH_TRUST_PROXY_HEADERS=1
DAILYDEX_ALLOWED_HOSTS=your-domain.example
PUBLIC_BASE_URL=https://your-domain.example
# Disabled by default in production because it can expose source files.
CODE_GRAPH_ENABLED=0

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: nvidia, openai, anthropic, ollama, gemini, opencode, claude, kilocode
LLM_PROVIDER=nvidia

# NVIDIA NIM (free tier available)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenAI (if using openai provider)
# OPENAI_API_KEY=

# Anthropic (if using anthropic provider)
# ANTHROPIC_API_KEY=

# Ollama (if using ollama provider — local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Notion Integration ──────────────────────────────────────────────────────
NOTION_API_TOKEN=
NOTION_DATABASE_ID=

# ── Telegram Bot (optional) ─────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── YouTube OAuth (optional, for video uploads) ─────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8888/api/youtube/callback

# ── ElevenLabs (optional, for voiceover) ────────────────────────────────────
# ELEVENLABS_API_KEY=

# ── Orchestrator Settings ───────────────────────────────────────────────────
ORCH_FETCH_INTERVAL=7200
ORCH_STUDIO_INTERVAL=21600
ORCH_TOP_N=3
ORCH_NOTION_SYNC=1

# ── Database ────────────────────────────────────────────────────────────────
# Leave empty for SQLite (default). Set for Postgres/Supabase.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Enrichment ──────────────────────────────────────────────────────────────
CREATOR_ENRICH_DAILY_LIMIT=60
CREATOR_ENRICHER_PRIMARY=1

# Vercel cron endpoints (not used by the Docker orchestrator)
# CRON_SECRET=
